# Copy to .env on the GPU server and edit local values. Never commit .env.

# Demo serving
TRACEHOUND_HOST=0.0.0.0
TRACEHOUND_PORT=8000

# Conda bootstrap
TRACEHOUND_ENV_NAME=tracehound-gpu
TRACEHOUND_PYTHON_VERSION=3.10
TRACEHOUND_INSTALL_TRAIN=1
TRACEHOUND_INSTALL_OFFICIAL=1
TRACEHOUND_INSTALL_PREFERENCE=0
TRACEHOUND_INSTALL_QLORA=0
TRACEHOUND_PREINSTALL_NATIVE_DEPS=1
TRACEHOUND_RUN_SMOKE=1
TRACEHOUND_START_DEMO=0
TRACEHOUND_AUTO_INSTALL_MINICONDA=0
TRACEHOUND_MINICONDA_DIR=$HOME/miniconda3
TRACEHOUND_TMPDIR=$HOME/.cache/tracehound/tmp

# Optional Hugging Face-compatible dataset mirror for restricted cluster networks.
# The default downloader uses https://huggingface.co when this is unset.
TRACEHOUND_HF_BASE_URL=https://hf-mirror.com

# Slurm cluster submission. Use this when login nodes do not expose GPUs.
TRACEHOUND_SLURM_PARTITION=ai4safe
TRACEHOUND_SLURM_GPUS=1
TRACEHOUND_SLURM_NTASKS=1
TRACEHOUND_SLURM_NTASKS_PER_NODE=1
TRACEHOUND_SLURM_CPUS_PER_TASK=
TRACEHOUND_SLURM_MEM=
TRACEHOUND_SLURM_MPI=
TRACEHOUND_SLURM_TIME=
TRACEHOUND_SLURM_LOG_DIR=log
TRACEHOUND_USE_APPTAINER=0
TRACEHOUND_APPTAINER_IMAGE=
TRACEHOUND_APPTAINER_BIND=$PWD:/workspace
TRACEHOUND_APPTAINER_WORKDIR=/workspace

# CUDA PyTorch install. Override for the contest image if needed.
# Common alternatives: cu121, cu124, cu126, or CPU-only by setting TRACEHOUND_SKIP_TORCH=1.
TRACEHOUND_SKIP_TORCH=0
TRACEHOUND_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# Optional API judge settings. Intern API is OpenAI-compatible.
TRACEHOUND_API_BASE=https://chat.intern-ai.org.cn/api/v1
TRACEHOUND_API_KEY=replace-with-your-api-key
TRACEHOUND_MODEL=intern-s2-preview
TRACEHOUND_API_PATH=/chat/completions
TRACEHOUND_API_TIMEOUT=60
TRACEHOUND_INPUT_PRICE_PER_1M=0
TRACEHOUND_OUTPUT_PRICE_PER_1M=0

# Optional local model metadata used by CLI, diagnostics, and the Web Demo model-ops page.
# First-choice local profile: internlm3-8b-instruct
# Smoke profile: internlm2_5-1_8b-chat
# Fallback formal profile: internlm2_5-7b-chat
TRACEHOUND_MODEL_PROFILE=internlm3-8b-instruct
# Default local guard: full-parameter TraceHound-Base binary checkpoint.
TRACEHOUND_GUARD_MODEL_PROFILE=tracehound-base-qwen3_5-0_8b-binary
TRACEHOUND_GUARD_MODEL_PATH=models/TraceHound-Base-Qwen3.5-0.8B-Binary
TRACEHOUND_LOCAL_MODEL=models/TraceHound-Base-Qwen3.5-0.8B-Binary
TRACEHOUND_LOCAL_MODEL_PATH=
