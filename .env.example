# Copy this file to .env and fill local values. Never commit .env.
TRACEHOUND_API_BASE=https://api.example.com/v1
TRACEHOUND_API_KEY=replace-with-your-api-key
TRACEHOUND_MODEL=replace-with-model-name

# Optional. Keep the default for OpenAI-compatible services.
TRACEHOUND_API_PATH=/chat/completions
TRACEHOUND_API_TIMEOUT=60

# Optional. Used only for estimated API cost accounting.
TRACEHOUND_INPUT_PRICE_PER_1M=0
TRACEHOUND_OUTPUT_PRICE_PER_1M=0
